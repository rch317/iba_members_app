{
  "family": "iba-membership",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "iba-membership",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/iba-membership:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",  "value": "production" },
        { "name": "PORT",      "value": "8080" }
      ],
      "secrets": [
        { "name": "MONGO_URI",             "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:iba-membership/MONGO_URI" },
        { "name": "GOOGLE_CLIENT_ID",      "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:iba-membership/GOOGLE_CLIENT_ID" },
        { "name": "GOOGLE_CLIENT_SECRET",  "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:iba-membership/GOOGLE_CLIENT_SECRET" },
        { "name": "GOOGLE_CALLBACK_URL",   "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:iba-membership/GOOGLE_CALLBACK_URL" },
        { "name": "SESSION_SECRET",        "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:iba-membership/SESSION_SECRET" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/iba-membership",
          "awslogs-region":        "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "curl -sf http://localhost:8080/health || exit 1"],
        "interval":    30,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 15
      }
    }
  ]
}
